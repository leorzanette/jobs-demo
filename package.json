{
  "name": "jobs-demo",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --mode demo",
    "build": "tsc -b && vite build --mode demo",
    "preview": "vite preview",
    "dev:prod": "vite",
    "build:prod": "tsc -b && vite build",
    "deploy": "npm run build && wrangler deploy",
    "pages:dev": "npm run build && wrangler pages dev dist",
    "pages:deploy": "npm run build && wrangler pages deploy dist --project-name=jobs-demo",
    "pages:deploy:prod": "npm run build:prod && wrangler pages deploy dist --project-name=jobs-demo",
    "d1:migrate": "wrangler d1 migrations apply jobs-demo --remote",
    "d1:migrate:local": "wrangler d1 migrations apply jobs-demo --local"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "jose": "^5.9.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250204.0",
    "@tailwindcss/vite": "^4.1.8",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "tailwindcss": "^4.1.8",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.107.1"
  }
}
